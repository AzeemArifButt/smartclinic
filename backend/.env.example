DATABASE_URL=postgresql://user:password@host:5432/smartclinic

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Meta Cloud API — system user permanent token
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# Any string you pick, entered in Meta webhook dashboard
WA_VERIFY_TOKEN=my-webhook-verify-token-123

# Public URL of this backend (used in QR codes)
APP_URL=https://your-backend.railway.app

# Public URL of the frontend
FRONTEND_URL=https://your-frontend.railway.app
